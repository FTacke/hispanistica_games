# =============================================================================
# games.hispanistica Environment Variables Example
# =============================================================================
#
# 1. Kopiere diese Datei zu ".env"
# 2. Fülle die Werte aus
# 3. NIEMALS ".env" zu Git committen!
#
# =============================================================================

# -----------------------------------------------------------------------------
# Flask Configuration
# -----------------------------------------------------------------------------

# CRITICAL: Set from secret manager
FLASK_SECRET_KEY=<SET_ME_FLASK_SECRET_KEY>

# Environment: development, production, testing
FLASK_ENV=<development|production|testing>

# Debug mode
FLASK_DEBUG=<true|false>

# Session cookie security
FLASK_SESSION_SECURE=<true|false>
FLASK_SESSION_SAMESITE=<lax|strict|none>

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------

JWT_PUBLIC_KEY_PATH=<config/keys/jwt_public.pem>
JWT_PRIVATE_KEY_PATH=<config/keys/jwt_private.pem>

# JWT signing key. Use JWT_SECRET_KEY (preferred) or legacy JWT_SECRET.
# For RSA use PRIVATE/PUBLIC key files above and set JWT_ALG to RS256.
JWT_SECRET_KEY=<SET_ME_JWT_SECRET_KEY>
JWT_ALG=<HS256|RS256>

# Which DB to use for auth (SQLAlchemy URL)
AUTH_DATABASE_URL=<postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME>

# Hashing algorithm for stored passwords
AUTH_HASH_ALGO=<argon2|bcrypt>

# Cookie security
JWT_COOKIE_SECURE=<true|false>

# Days after soft-delete to anonymize account
AUTH_ACCOUNT_ANONYMIZE_AFTER_DAYS=<30>

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------

# Docker network name
DOCKER_NETWORK=<games-network|corapan-network>

# =============================================================================
# Admin User Bootstrap (DEVELOPMENT ONLY)
# =============================================================================
#
# IMPORTANT: In production, DO NOT set these variables on normal deployments.
# Only set them on FIRST deployment (initial setup).
#
# For password resets in production, use the CLI command:
#   python scripts/admin_reset_password.py --username admin --password newpass
#
# To enable admin bootstrap on first deployment:
#   1. Set ADMIN_BOOTSTRAP=1 (this triggers bootstrap in docker-entrypoint.sh)
#   2. Set START_ADMIN_PASSWORD=<secure_password>
#   3. Deploy
#   4. Remove both variables from subsequent deployments
#
# Variables:
#   ADMIN_BOOTSTRAP=1          (must be set to enable)
#   START_ADMIN_USERNAME=admin (defaults to "admin" if not set)
#   START_ADMIN_PASSWORD=...   (REQUIRED if ADMIN_BOOTSTRAP=1)

ADMIN_BOOTSTRAP=<0|1>
START_ADMIN_USERNAME=<admin>
START_ADMIN_PASSWORD=<SET_ONLY_FOR_INITIAL_BOOTSTRAP>
